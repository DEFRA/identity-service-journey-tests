{
  "name": "identity-service-journey-tests",
  "version": "1.0.0",
  "description": "E2E Journey tests for Identity Service Backend and Frontend",
  "engines": {
    "node": ">=24.13.0"
  },
  "keywords": [
    "e2e",
    "playwright",
    "testautomation",
    "uat"
  ],
  "homepage": "https://github.com/DEFRA/identity-service-journey-tests#README.md",
  "bugs": {
    "url": "https://github.com/DEFRA/identity-service-journey-tests/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DEFRA/identity-service-journey-tests.git"
  },
  "license": "OGL-UK-3.0",
  "author": "Ransom Voke Anighoro",
  "scripts": {
    "clean": "rimraf dist allure-results allure-report playwright-report test-results",
    "format": "prettier --write \"tests/**/*.ts\" \"**/*.{ts,md,json,config.ts}\"",
    "format:check": "prettier --check \"tests/**/*.ts\" \"**/*.{ts,md,json,config.ts}\"",
    "git:pre-commit-hook": "npm run format:check && npm run lint",
    "lint": "eslint \"tests/**/*.ts\" \"playwright.config.ts\"",
    "lint:fix": "eslint \"tests/**/*.ts\" \"playwright.config.ts\" --fix",
    "merge:report": "npx ctrf merge playwright-report/",
    "prepare": "husky",
    "test": "npm run test:playwright",
    "test:playwright": "npx playwright install && npm run clean && npx bddgen && npx playwright test --config=playwright.config.ts",
    "report": "allure generate allure-results --single-file --clean",
    "report:publish": "npm run report; ./bin/publish-tests.sh"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "@types/node": "25.6.0",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "allure-commandline": "2.40.0",
    "allure-playwright": "3.7.1",
    "commitlint": "20.5.0",
    "dotenv": "17.4.2",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.5.0",
    "http-status-codes": "2.3.0",
    "husky": "9.1.7",
    "jiti": "2.6.1",
    "lint-staged": "16.4.0",
    "playwright": "1.60.0",
    "playwright-bdd": "9.0.0",
    "playwright-ctrf-json-reporter": "0.0.29",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.2",
    "uuid": "14.0.0"
  }
}
